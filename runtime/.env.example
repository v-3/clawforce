# Copy to runtime/.env and fill in.
# `source ../ai-tutor.env` first to populate AGENT_ID / ENV_ID / MEMORY_STORE_ID
# from the setup output, then add the Slack values below.

# --- from ai-tutor.env (populated by setup.sh) ---
ANTHROPIC_API_KEY=
AGENT_ID=
AGENT_VERSION=
ENV_ID=
MEMORY_STORE_ID=

# --- Slack: bot creds + identity gate ---
# Bot token: Slack app → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-

# Signing secret: Slack app → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=

# Your Slack user ID (NOT username). Find it via:
#   Slack profile → ⋮ → Copy member ID. Starts with U.
ALLOWED_SLACK_USER_ID=U

# DM channel ID with your bot. After installing the bot, send it any DM and
# read the channel ID from the URL or via `conversations.open`. Starts with D.
DEFAULT_DM_CHANNEL=D
